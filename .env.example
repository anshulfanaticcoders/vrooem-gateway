# ─── Gateway ───
GATEWAY_ENV=local
GATEWAY_DEBUG=true
GATEWAY_API_KEYS=dev_key_change_me
GATEWAY_SECRET=hmac_secret_change_me

# ─── Database (Supabase in production) ───
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vrooem_gateway

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── Laravel (for internal vehicle adapter) ───
LARAVEL_BASE_URL=http://localhost:8000
LARAVEL_API_TOKEN=laravel_internal_token

# ─── Provider Credentials ───
# GreenMotion
GREENMOTION_API_URL=https://otatest.greenmotion.com
GREENMOTION_USERNAME=
GREENMOTION_PASSWORD=

# Renteon
RENTEON_API_URL=https://api.renteon.com
RENTEON_USERNAME=
RENTEON_PASSWORD=

# Favrica
FAVRICA_API_URL=https://api.turev.com/favrica
FAVRICA_TOKEN=

# XDrive (same Turev platform as Favrica)
XDRIVE_API_URL=https://api.turev.com/xdrive
XDRIVE_TOKEN=

# EMR Car Rental (same Turev platform as Favrica/XDrive)
EMR_API_URL=https://emrjson.turevrent.com
EMR_TOKEN=
EMR_USERNAME=
EMR_PASSWORD=

# Adobe Car
ADOBE_API_URL=https://www.adobecarrental.com/api
